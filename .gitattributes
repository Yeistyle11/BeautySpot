# Normalize line endings across platforms (prettier endOfLine: "lf")
* text=auto eol=lf

# Source code (LF)
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.json5     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.env*      text eol=lf
*.sh        text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.eslintrc*  text eol=lf
.prettierrc text eol=lf
.editorconfig text eol=lf

# Windows-only scripts (CRLF)
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets (no line ending conversion)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary

# Lockfiles (preserve as-is in working tree, normalize in index)
package-lock.json  text eol=lf
pnpm-lock.yaml     text eol=lf
