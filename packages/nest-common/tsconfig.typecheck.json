{
  // Chequeo de tipos que SI cubre los tests y el setup de Jest. El tsconfig
  // principal los excluye porque ahi `tsc` emite y no deben acabar en dist;
  // aqui solo se verifica, y `rootDir` se abre a la raiz para poder incluir
  // test-setup.ts, que vive fuera de src.
  "extends": "./tsconfig.json",
  "compilerOptions": { "noEmit": true, "rootDir": "." },
  "include": ["src", "test-setup.ts"],
  "exclude": ["node_modules", "dist"]
}
