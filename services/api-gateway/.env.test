# API Gateway - Test Environment
NODE_ENV=test
PORT=3000

# Services - Test URLs
AUTH_SERVICE_URL=http://localhost:3001
CORE_SERVICE_URL=http://localhost:3002
BOOKING_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005
MARKETPLACE_SERVICE_URL=http://localhost:3006
ANALYTICS_SERVICE_URL=http://localhost:3007

# JWT - Test
JWT_SECRET=test_secret_key_for_testing_only_do_not_use_in_production
JWT_REFRESH_SECRET=test_refresh_secret_for_testing_only_do_not_use_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis - Test
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_test

# RabbitMQ - Test
RABBITMQ_URL=amqp://beautyspot_test:test123@localhost:5673

# CORS - Test
CORS_ORIGINS=http://localhost:3000

# Rate Limiting - Test (relajado para tests)
RATE_LIMIT_AUTH_MAX=1000
RATE_LIMIT_GENERAL_MAX=10000