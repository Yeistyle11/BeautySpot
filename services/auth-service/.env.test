# Auth Service - Test Environment
NODE_ENV=test
PORT=3001

# Database - Test
DATABASE_URL=postgresql://postgres:postgres_test@localhost:5434/beautyspot_auth_test

# Redis - Test
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_test

# RabbitMQ - Test
RABBITMQ_URL=amqp://beautyspot_test:test123@localhost:5673

# JWT - Test
JWT_SECRET=test_secret_key_for_testing_only_do_not_use_in_production
JWT_REFRESH_SECRET=test_refresh_secret_for_testing_only_do_not_use_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt - Test
BCRYPT_SALT_ROUNDS=4

# Internal API - Test
INTERNAL_API_SECRET=test_internal_secret_for_testing_only

# CORS - Test
CORS_ORIGINS=http://localhost:3000

# Rate Limiting - Test (relajado para tests)
RATE_LIMIT_AUTH_MAX=1000
RATE_LIMIT_GENERAL_MAX=10000