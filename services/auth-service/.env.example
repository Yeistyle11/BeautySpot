PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/beautyspot_auth
# OBLIGATORIO: generar un secret aleatorio de al menos 32 caracteres. La app falla al arranque si no está configurado o si es el valor por defecto.
JWT_SECRET=
# OBLIGATORIO: debe ser DISTINTO de JWT_SECRET. Mínimo 32 caracteres.
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
RABBITMQ_URL=amqp://beautyspot:beautyspot123@localhost:5672
# OBLIGATORIO: secret aleatorio compartido entre servicios.
INTERNAL_API_SECRET=
CORS_ORIGINS=http://localhost:3000
