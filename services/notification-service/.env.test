# Notification Service - Test Environment
NODE_ENV=test
PORT=3005

# Database - Test
DATABASE_URL=postgresql://postgres:postgres_test@localhost:5434/beautyspot_notification_test

# Redis - Test
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_test

# RabbitMQ - Test
RABBITMQ_URL=amqp://beautyspot_test:test123@localhost:5673

# SMTP - Test (dummy config, no se enviarán emails reales en tests)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test_password
EMAIL_FROM=noreply@beautyspot-test.co

# Internal API - Test
INTERNAL_API_SECRET=test_internal_secret_for_testing_only

# CORS - Test
CORS_ORIGINS=http://localhost:3000

# Rate Limiting - Test (relajado para tests)
RATE_LIMIT_GENERAL_MAX=10000